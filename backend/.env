# JWT — two different secrets for access and refresh tokens
JWT_ACCESS_SECRET="change-me-32-chars-minimum-access-secret"
JWT_REFRESH_SECRET="change-me-32-chars-minimum-refresh-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# AI
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# Market Data
ALPHA_VANTAGE_KEY="your-alpha-vantage-key-here"

# App
NODE_ENV="development"
PORT="3000"
FRONTEND_URL="http://localhost:3001"
BCRYPT_ROUNDS="12"
