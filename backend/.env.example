# Database — Railway provides this automatically when you add a Postgres plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Redis — Railway provides this automatically when you add a Redis plugin
REDIS_URL="redis://:password@host:6379"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="<generate-random-96-char-hex>"
JWT_REFRESH_SECRET="<generate-different-random-96-char-hex>"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Anthropic — get from https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# Market data — get free key from https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY="your-key-here"

# App
NODE_ENV="production"
PORT="3000"
FRONTEND_URL="https://your-vercel-app.vercel.app"
BCRYPT_ROUNDS="12"
